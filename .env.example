# ===========================================
# ProjectWizard - Environment Variables
# ===========================================
# Kopieer dit bestand naar .env.local en vul de waardes in

# -------------------------------------------
# Supabase (Database & Auth)
# -------------------------------------------
# Je Supabase instance URL
SUPABASE_URL=http://your-supabase-host:8000
# Publishable key (Dashboard → API Keys → Publishable)
SUPABASE_ANON_KEY=sb_publishable_...
# Secret key — GEHEIM (Dashboard → API Keys → Secret)
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...

# Dashboard login (indien nodig)
# SUPABASE_DASHBOARD_USERNAME=
# SUPABASE_DASHBOARD_PASSWORD=

# -------------------------------------------
# Anthropic Claude API
# -------------------------------------------
# Krijg je key op: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your-anthropic-api-key

# -------------------------------------------
# Applicatie Settings
# -------------------------------------------
PUBLIC_APP_NAME=ProjectWizard
PUBLIC_DEFAULT_LANGUAGE=nl

# -------------------------------------------
# Development
# -------------------------------------------
NODE_ENV=development
